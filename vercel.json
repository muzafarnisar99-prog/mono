{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{"type": "host", "value": "www.monobenzone.shop"}],
      "destination": "https://monobenzone.shop/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "X-Frame-Options", "value": "DENY"}
      ]
    }
  ]
}
